# =============================================================================
# Environment variables
# Copy to .env and fill in ALL values
# =============================================================================

# --- Frontend URLs (baked into Next.js bundles at build time) ---
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Database ---
DATABASE_PASSWORD=

# --- Redis ---
# Leave empty for no password
REDIS_PASSWORD=

# --- gRPC ---
GRPC_PORT=9090

# --- JWT ---
JWT_ISSUER=zunftgewerk
JWT_AUDIENCE=zunftgewerk-clients
JWT_KID=prod-key-1
JWT_ACCESS_TTL_SECONDS=900
JWT_MFA_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
# Generate with: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=

# --- MFA ---
# 32-char hex key for AES-128-GCM TOTP encryption
MFA_ENCRYPTION_KEY=

# --- Field Encryption (Auftragsabwicklung) ---
# Enable AES-256-GCM field encryption for sensitive business fields
FIELD_ENCRYPTION_ENABLED=false
# Base64 encoded 32-byte key (example generation: openssl rand -base64 32)
FIELD_ENCRYPTION_KEY=
# Key version marker for rotation workflows
FIELD_ENCRYPTION_KEY_VERSION=v1

# --- Auth Cookies ---
AUTH_COOKIE_SAMESITE=None
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_DOMAIN=.example.com
AUTH_COOKIE_PATH=/
AUTH_COOKIE_MAX_AGE_SECONDS=2592000

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com,https://app.example.com

# --- Rate Limiting ---
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_LOGIN_LIMIT=5
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_PASSKEY_LIMIT=10
AUTH_RATE_LIMIT_PASSKEY_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MFA_LIMIT=10
AUTH_RATE_LIMIT_MFA_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_REFRESH_LIMIT=30
AUTH_RATE_LIMIT_REFRESH_WINDOW_SECONDS=60

# --- Feature Flags ---
FEATURE_MFA_ENFORCEMENT_ADMIN=true
FEATURE_STRIPE_BILLING=true
FEATURE_PASSKEY_AUTH=true
FEATURE_AUTH_V2_ENABLED=true
FEATURE_SYNC_ENGINE_V1=true
FEATURE_CUSTOM_ROLES=true
FEATURE_STRIPE_WEBHOOK_ENABLED=true
FEATURE_SYNC_VECTOR_RESOLVER_ENABLED=true

# --- Passkey/WebAuthn (must match web app origin exactly) ---
PASSKEY_RP_ID=example.com
PASSKEY_RP_NAME=Zunftgewerk
PASSKEY_ORIGIN=https://app.example.com

# --- SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_SSL=false
MAIL_FROM=noreply@example.com
EMAIL_FROM_NAME=ZunftGewerk

# --- Email Links ---
LANDING_BASE_URL=https://example.com
API_BASE_URL=https://api.example.com

# --- Email Verification / Password Reset ---
EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_PROFESSIONAL_YEARLY=price_...
STRIPE_RETRY_WORKER_ENABLED=true
STRIPE_RETRY_SCAN_INTERVAL_SECONDS=30
STRIPE_RETRY_BATCH_SIZE=50
STRIPE_RETRY_MAX_ATTEMPTS=5
STRIPE_RETRY_BASE_DELAY_SECONDS=30
STRIPE_RETRY_MAX_DELAY_SECONDS=3600
STRIPE_INGEST_WORKER_ENABLED=true
STRIPE_INGEST_SCAN_INTERVAL_SECONDS=5
STRIPE_INGEST_BATCH_SIZE=50
STRIPE_DEAD_LETTER_RECOVERY_ENABLED=true
STRIPE_DEAD_LETTER_RECOVERY_INTERVAL_SECONDS=300
STRIPE_DEAD_LETTER_COOLDOWN_SECONDS=3600
STRIPE_DEAD_LETTER_MAX_RECOVERY_ATTEMPTS=3
STRIPE_OPS_RECOVERY_TOKEN=

# --- Address Geocoding (OpenRouteService) ---
OPENROUTESERVICE_BASE_URL=https://api.openrouteservice.org/geocode
OPENROUTESERVICE_API_KEY=
ADDRESS_API_TIMEOUT_MS=4000

# --- Observability ---
OTEL_TRACING_ENABLED=false
OTEL_SAMPLING_PROBABILITY=0.1
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# --- Internal / Ops ---
INTERNAL_OPS_TOKEN=
