# Required
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=your-password
# Base32-encoded TOTP secret (A-Z, 2-7 only). Example: JBSWY3DPEHPK3PXP
# Hex-encoded secrets (0-9, a-f) are also supported.
E2E_ADMIN_TOTP_SECRET=JBSWY3DPEHPK3PXP

# Optional
E2E_BASE_URL=http://127.0.0.1:3001
E2E_API_BASE_URL=http://localhost:8080
